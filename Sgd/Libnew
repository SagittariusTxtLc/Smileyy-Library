local _window      = nil
local _loaded      = false
local _pendingShow = nil

-- HELPERS
local function _style(obj, strokeColor)
	Instance.new("UICorner", obj)
	local s = Instance.new("UIStroke", obj)
	s.Color = strokeColor or Color3.fromRGB(60,60,60)
	s.Thickness = 1
end

-- CREATE WINDOW (single window only)
function Lib:CreateWindow(title)

	local frame = Instance.new("Frame")
	frame.Size             = UDim2.new(0, 230, 0, 100)
	frame.Position         = UDim2.new(0, 15, 0, 10)
	frame.BackgroundColor3 = Color3.fromRGB(10,10,10)
	frame.ClipsDescendants = true
	frame.Active           = true
	frame.Visible          = false
	frame.ZIndex           = 10
	frame.Parent           = _gui
	Instance.new("UICorner", frame)
	local fStroke = Instance.new("UIStroke", frame)
	fStroke.Thickness = 2

	-- Black and white faded stroke animation
	task.spawn(function()
		local t = 0
		while frame and frame.Parent do
			t = t + 0.03
			local brightness = (math.sin(t) + 1) / 2
			fStroke.Color = Color3.fromRGB(
				math.floor(brightness * 255),
				math.floor(brightness * 255),
				math.floor(brightness * 255)
			)
			task.wait(0.03)
		end
	end)

	-- TITLE BAR
	local titleBar = Instance.new("Frame")
	titleBar.Size             = UDim2.new(1,0,0,45)
	titleBar.BackgroundColor3 = Color3.fromRGB(15,15,15)
	titleBar.BorderSizePixel  = 0
	titleBar.ZIndex           = 11
	titleBar.Active           = true
	titleBar.Parent           = frame
	Instance.new("UICorner", titleBar)

	local titleLbl = Instance.new("TextLabel")
	titleLbl.Size               = UDim2.new(1,-50,1,0)
	titleLbl.Position           = UDim2.new(0,12,0,0)
	titleLbl.Text               = "Smileyy Hub | " .. string.upper(title or "Window")
	titleLbl.Font               = Enum.Font.GothamBold
	titleLbl.TextSize           = 14
	titleLbl.TextColor3         = Color3.fromRGB(255,255,255)
	titleLbl.BackgroundTransparency = 1
	titleLbl.TextXAlignment     = Enum.TextXAlignment.Left
	titleLbl.ZIndex             = 12
	titleLbl.Parent             = titleBar

	-- COLLAPSE BUTTON
	local colBtn = Instance.new("TextButton")
	colBtn.Size               = UDim2.new(0,30,0,30)
	colBtn.Position           = UDim2.new(1,-38,0.5,-15)
	colBtn.Text               = "v"
	colBtn.BackgroundColor3   = Color3.fromRGB(25,25,25)
	colBtn.Font               = Enum.Font.GothamBold
	colBtn.TextSize           = 16
	colBtn.TextColor3         = Color3.fromRGB(255,255,255)
	colBtn.ZIndex             = 12
	colBtn.Parent             = titleBar
	local cc = Instance.new("UICorner", colBtn)
	cc.CornerRadius = UDim.new(0,6)

	-- SCROLL
	local scroll = Instance.new("ScrollingFrame")
	scroll.Size                = UDim2.new(1,0,1,-45)
	scroll.Position            = UDim2.new(0,0,0,45)
	scroll.BackgroundTransparency = 1
	scroll.ScrollBarThickness  = 4
	scroll.CanvasSize          = UDim2.new(0,0,0,0)
	scroll.ZIndex              = 11
	scroll.Parent              = frame

	local layout = Instance.new("UIListLayout")
	layout.Padding   = UDim.new(0,5)
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Parent    = scroll

	local pad = Instance.new("UIPadding")
	pad.PaddingTop    = UDim.new(0,5)
	pad.PaddingBottom = UDim.new(0,5)
	pad.PaddingLeft   = UDim.new(0,5)
	pad.PaddingRight  = UDim.new(0,5)
	pad.Parent        = scroll

	local collapsed = false
	local function updateCanvas()
		task.defer(function()
			scroll.CanvasSize = UDim2.new(0,0,0, layout.AbsoluteContentSize.Y + 10)
			if not collapsed then
				frame.Size = UDim2.new(0, 230, 0,
					math.clamp(layout.AbsoluteContentSize.Y + 55, 100, 450))
			end
		end)
	end
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(updateCanvas)

	-- COLLAPSE LOGIC
	colBtn.MouseButton1Click:Connect(function()
		collapsed = not collapsed
		if collapsed then
			colBtn.Text = ">"
			TweenService:Create(frame, TweenInfo.new(0.25), {Size = UDim2.new(0,230,0,45)}):Play()
		else
			colBtn.Text = "v"
			TweenService:Create(frame, TweenInfo.new(0.25), {
				Size = UDim2.new(0,230,0, math.clamp(layout.AbsoluteContentSize.Y + 55, 100, 450))
			}):Play()
		end
	end)

	-- DRAG
	local dragging  = false
	local dragStart = nil
	local startPos  = nil

	titleBar.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
		or i.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = i.Position
			startPos = frame.Position
		end
	end)
	titleBar.InputEnded:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1
		or i.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	UIS.InputChanged:Connect(function(i)
		if not dragging then return end
		if i.UserInputType == Enum.UserInputType.MouseMovement
		or i.UserInputType == Enum.UserInputType.Touch then
			local sc    = workspace.CurrentCamera.ViewportSize
			local delta = i.Position - dragStart
			local newX  = math.clamp(startPos.X.Offset + delta.X, 0, math.max(0, sc.X - frame.AbsoluteSize.X))
			local newY  = math.clamp(startPos.Y.Offset + delta.Y, 0, math.max(0, sc.Y - frame.AbsoluteSize.Y))
			frame.Position = UDim2.new(0, newX, 0, newY)
		end
	end)

	-- ANTI OUT OF SCREEN
	RunService.RenderStepped:Connect(function()
		if not frame or not frame.Parent then return end
		local sc  = workspace.CurrentCamera.ViewportSize
		local pos = frame.Position
		local x   = math.clamp(pos.X.Offset, 0, math.max(0, sc.X - frame.AbsoluteSize.X))
		local y   = math.clamp(pos.Y.Offset, 0, math.max(0, sc.Y - frame.AbsoluteSize.Y))
		if x ~= pos.X.Offset or y ~= pos.Y.Offset then
			frame.Position = UDim2.new(0, x, 0, y)
		end
	end)

	if _loaded then
		frame.Visible = true
	else
		_pendingShow = function() frame.Visible = true end
	end

	_window = frame

	local Win    = {}
	local _order = 0
	local function nxt() _order += 1; return _order end

